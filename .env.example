# Clew local environment
# Copy this file to .env and fill in at least one provider key.
# All values are optional — without keys the UI runs but AI features are disabled.

# --- AI provider keys (set at least one) ---
# KG_GEMINI_API_KEY=
# KG_OPENAI_API_KEY=

# --- OpenAI-compatible endpoints (optional) ---
# Override only if you use an OpenAI-compatible proxy (e.g. local LLM, OpenRouter).
# KG_OPENAI_BASE_URL=https://api.openai.com/v1

# --- Provider selection (optional) ---
# Defaults to gemini. Switch to openai if you only have an OpenAI key.
# KG_AI_PROVIDER=gemini
